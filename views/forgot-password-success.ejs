<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Success</title>

  <style>
    body {
      margin: 0;
      font-family: system-ui, Arial;
      background: #0b1220;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      color: white;
    }

    .card {
      background: #111827;
      padding: 40px;
      border-radius: 16px;
      text-align: center;
      width: 360px;
      box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    }

    .icon {
      font-size: 50px;
      margin-bottom: 15px;
    }

    h2 {
      margin: 0 0 10px 0;
    }

    p {
      font-size: 14px;
      color: #9ca3af;
    }

    a {
      display: inline-block;
      margin-top: 20px;
      padding: 10px 15px;
      background: #3b82f6;
      color: white;
      text-decoration: none;
      border-radius: 10px;
    }

    a:hover {
      background: #2563eb;
    }
  </style>
</head>

<body>

  <div class="card">
    <div class="icon">📩</div>

    <h2>Email Sent</h2>

    <p>
      Password reset link has been sent to your email.
      Please check your inbox.
    </p>

    <a href="/login">Back to Login</a>
  </div>

</body>
</html>